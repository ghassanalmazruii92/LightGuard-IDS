# ─── LightGuard Environment Template ────────────────────────────────────────
# Copy this file to config/lightguard.env and fill in your values.
# NEVER commit the real .env file.

# Network interface for live packet capture (e.g., eth0, wlan0, ens33)
NETWORK_INTERFACE=eth0

# CIDR range for network scanning
NETWORK_CIDR=192.168.1.0/24

# Set to "false" to enable real packet capture (requires root)
MOCK_MODE=true

# JWT secret key — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# TLS certificate paths (for HTTPS — generate with mkcert or Let's Encrypt)
SSL_CERTFILE=ssl/cert.pem
SSL_KEYFILE=ssl/key.pem

# Database URL (default: SQLite)
# LIGHTGUARD_DATABASE_URL=postgresql://user:pass@localhost/lightguard

# Scan interval (seconds)
SCAN_INTERVAL=60
MASSCAN_RATE=1000
