# ── Tadhamon Smart City Config ─────────────────────────────
CITY_NAME=مدينة التضامن الذكية
CITY_NAME_EN=Tadhamon Smart City

# ── Network ────────────────────────────────────────────────
NETWORK_CIDR=192.168.1.0/24      # ← Change to your actual LAN
NETWORK_INTERFACE=eth0            # ← Change to your interface (ip link show)
SCAN_INTERVAL=30                  # seconds between ARP sweeps
MASSCAN_RATE=1000                 # packets/sec

# ── Security ───────────────────────────────────────────────
JWT_SECRET=change-this-in-production-tadhamon-2025
JWT_EXPIRE_HOURS=24

# ── Mode ───────────────────────────────────────────────────
MOCK_MODE=true                   # default to true for safe local testing
